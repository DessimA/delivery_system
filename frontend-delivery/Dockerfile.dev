# Dockerfile para Desenvolvimento com Hot-Reload
FROM node:20-alpine

WORKDIR /app

# Copiar package.json e package-lock.json
COPY package*.json ./

# Instalar dependências
RUN npm install

# Expor porta do Vite dev server
EXPOSE 5173

# Comando padrão (será sobrescrito no docker-compose)
CMD ["npm", "run", "dev"]
